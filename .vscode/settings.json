{
	"editor.formatOnSave": true,
	"editor.minimap.enabled": false,
	"editor.mouseWheelZoom": true,
	"editor.quickSuggestions": { "strings": true },
	"editor.codeActionsOnSave": { "source.fixAll": "explicit" },
	"editor.acceptSuggestionOnCommitCharacter": false,
	"editor.acceptSuggestionOnEnter": "smart",
	"editor.suggest.localityBonus": true,
	"editor.gotoLocation.multipleDefinitions": "goto",
	// Setting Prettier as default formatter
	"editor.defaultFormatter": "esbenp.prettier-vscode",

	"emmet.extensionsPath": ["C:/Users/Igro-Zona/Desktop/ABOBA/FutureTech"],
	"emmet.showExpandedAbbreviation": "always",
	"emmet.showSuggestionsAsSnippets": true,
	"emmet.triggerExpansionOnTab": true,
	"emmet.preferences": { "output.reverseAttributes": true },

	"terminal.integrated.fontFamily": "Cascadia Code, Consolas, Courier New",
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.env.windows": {},

	"explorer.confirmDelete": false,
	"explorer.sortOrder": "type",
	"explorer.fileNesting.expand": false,

	"js/ts.format.insertSpaceAfterConstructor": true,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": true,
	"js/ts.format.semicolons": "insert",
	"js/ts.preferences.quoteStyle": "double",
	"js/ts.preferGoToSourceDefinition": true,
	"js/ts.referencesCodeLens.enabled": true,
	"js/ts.referencesCodeLens.showOnAllFunctions": true,
	"js/ts.implicitProjectConfig.checkJs": true,
	"js/ts.inlayHints.parameterNames.enabled": "all",
	"js/ts.updateImportsOnFileMove.enabled": "never",

	"workbench.iconTheme": "material-icon-theme",
	"workbench.editor.empty.hint": "hidden",
	"workbench.colorTheme": "Dark Modern",
	"workbench.browser.openLocalhostLinks": false,

	"files.eol": "\n",

	"git.autofetch": true,

	"material-icon-theme.activeIconPack": "vue_vuex",

	"files.associations": { "*.css": "tailwindcss" },

	"tailwindCSS.classAttributes": ["class", "ui"],
	"tailwindCSS.experimental.classRegex": [["ui:\\s*{([^)]*)\\s*}", "(?:'|\"|`)([^']*)(?:'|\"|`)"]],

	// PRETTIER SETTINGS START

	// Prettier extension
	"prettier.configPath": "prettier.config.ts",
	"prettier.enable": true,
	"prettier.enableDebugLogs": true,
	"prettier.ignorePath": ".prettierignore",
	"prettier.prettierPath": "./node_modules/prettier",
	"prettier.requireConfig": false,
	"prettier.resolveGlobalModules": false,
	"prettier.useEditorConfig": true,
	"prettier.withNodeModules": false,

	// Prettier config
	"prettier.arrowParens": "always",
	"prettier.bracketSameLine": false,
	"prettier.bracketSpacing": true,
	"prettier.embeddedLanguageFormatting": "auto",
	"prettier.endOfLine": "lf",
	"prettier.experimentalTernaries": false,
	"prettier.htmlWhitespaceSensitivity": "css",
	"prettier.insertPragma": false,
	"prettier.jsxSingleQuote": false,
	"prettier.printWidth": 120,
	"prettier.proseWrap": "always",
	"prettier.quoteProps": "consistent",
	"prettier.requirePragma": false,
	"prettier.semi": true,
	"prettier.singleAttributePerLine": true,
	"prettier.singleQuote": false,
	"prettier.tabWidth": 4,
	"prettier.trailingComma": "all",
	"prettier.useTabs": true,
	"prettier.vueIndentScriptAndStyle": false

	// PRETTIER SETTINGS END
}
